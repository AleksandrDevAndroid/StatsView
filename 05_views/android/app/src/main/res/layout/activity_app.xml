<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.AppActivity">

    <TextView
        android:id="@+id/label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Status" />

    <ru.netology.nmedia.ui.StatsView
        android:id="@+id/stats"
        android:layout_width="300dp"
        android:layout_height="300dp"
        app:lineWidth="20dp"
        app:fontSize="50dp"
        app:colors="@array/colors"
        app:layout_constraintTop_toBottomOf="@id/label"
        app:layout_constraintBottom_toTopOf="@id/button_one"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/button_one"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="@string/parallel"
        app:layout_constraintTop_toTopOf="@id/stats"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/button_two"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="@string/sequential"
        app:layout_constraintTop_toBottomOf="@id/button_one"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <Button
        android:id="@+id/button_three"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="@string/bilateral"
        app:layout_constraintTop_toBottomOf="@id/button_two"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
